modules = ["web", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_ENV = "development"
APP_SECRET_KEY = "dev-secret-key-change-in-production"
APP_PORT = "8000"
ALLOWED_ORIGINS = "http://localhost:8000,http://127.0.0.1:8000"
SUPABASE_URL = "https://placeholder.supabase.co"
SUPABASE_ANON_KEY = "placeholder-anon-key"
SUPABASE_SERVICE_ROLE_KEY = "placeholder-service-role-key"
SUPABASE_JWT_SECRET = "placeholder-jwt-secret"
MPESA_ENV = "sandbox"
AT_USERNAME = "sandbox"
LOG_LEVEL = "INFO"

[workflows]
runButton = "Start KaziX"

[[workflows.workflow]]
name = "Start KaziX"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 8000
externalPort = 80
exposeLocalhost = true

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000"]
